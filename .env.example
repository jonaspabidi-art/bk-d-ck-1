# ── E-post (Gmail) ─────────────────────────────────────────────
# 1. Aktivera tvåstegsverifiering på ditt Gmail-konto
# 2. Gå till myaccount.google.com → Säkerhet → Applösenord
# 3. Skapa ett applösenord för "Mail" och klistra in det nedan
EMAIL_USER=bkdaeck@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Butikens e-post ────────────────────────────────────────────
# Hit skickas notis vid ny bokning (kan vara samma som EMAIL_USER)
SHOP_EMAIL=bkdaeck@gmail.com

# ── Google Reviews-länk ────────────────────────────────────────
# Hitta länken: Sök på "BK Däck Göteborg" på Google Maps
# → Dela → Kopiera länk, eller be Google om din Place ID
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_PLACE_ID/review

# ── Admin-lösenord ─────────────────────────────────────────────
# Sätt ett eget lösenord här
ADMIN_PASSWORD=bkdaeck2024

# ── JWT-nyckel ─────────────────────────────────────────────────
# Generera med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ── Server-port (valfritt) ─────────────────────────────────────
# PORT=3000
